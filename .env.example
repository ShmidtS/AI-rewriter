# =============================================================================
# AI-rewriter Configuration v2.0
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All settings support legacy variable names for backward compatibility.
# =============================================================================

# =============================================================================
# CONNECTION PROFILE
# =============================================================================
# Determines how the application connects to the LLM API.
# Options: direct, proxy, auto
#
# - direct: Connect directly to API provider (OpenAI, Google, etc.)
# - proxy: Connect through local proxy (E:\456\LLM-API-Key-Proxy)
# - auto: Try proxy first, fallback to direct if unavailable
#
CONNECTION_PROFILE=proxy

# =============================================================================
# PROXY SETTINGS (for E:\456\LLM-API-Key-Proxy)
# =============================================================================
# Used when CONNECTION_PROFILE=proxy or CONNECTION_PROFILE=auto
#
# Proxy base URL (OpenAI-compatible endpoint)
PROXY_BASE_URL=http://127.0.0.1:8000/v1

# API key for proxy authentication
# IMPORTANT: Replace with your actual proxy API key
PROXY_API_KEY=your-proxy-api-key-here

# Connection timeout in seconds (default: 30)
PROXY_TIMEOUT_CONNECT=30

# Read timeout for streaming responses in seconds (default: 300)
PROXY_TIMEOUT_READ_STREAMING=300

# Enable healthcheck before requests (default: true)
PROXY_HEALTHCHECK_ENABLED=true

# =============================================================================
# DIRECT API SETTINGS
# =============================================================================
# Used when CONNECTION_PROFILE=direct or as fallback in auto mode
#
# Direct API base URL (e.g., OpenAI, Google AI Studio)
DIRECT_BASE_URL=https://api.openai.com/v1

# Direct API key
# IMPORTANT: Replace with your actual API key
DIRECT_API_KEY=your-direct-api-key-here

# =============================================================================
# MODEL SETTINGS
# =============================================================================
# Model name in provider/model format
# Examples:
#   - gemini/gemini-2.5-flash (Google Gemini via proxy)
#   - openai/gpt-4o (OpenAI GPT-4)
#   - colin/gpt-5.4 (Custom model via proxy)
MODEL_NAME=gemini/gemini-2.5-flash

# Model context window size (default: 1000000)
MODEL_CONTEXT_WINDOW=1000000

# Maximum output tokens per request (default: 32768)
MODEL_MAX_OUTPUT_TOKENS=32768

# Default temperature for generation (default: 1.0, range: 0.0-2.0)
MODEL_TEMPERATURE=1.0

# =============================================================================
# REWRITE PROCESS SETTINGS
# =============================================================================
# Target block size in characters (default: 15000)
REWRITE_BLOCK_TARGET_CHARS=15000

# Minimum rewrite length ratio (default: 0.40)
REWRITE_MIN_REWRITE_LENGTH_RATIO=0.40

# Maximum rewrite length ratio (default: 1.6)
REWRITE_MAX_REWRITE_LENGTH_RATIO=1.60

# Maximum retries per block (default: 20)
REWRITE_MAX_RETRIES=20

# Delay between retries in seconds (default: 2)
REWRITE_RETRY_DELAY_SECONDS=2

# =============================================================================
# UI SETTINGS
# =============================================================================
# UI language: ru, en, zh (default: ru)
UI_LANG=ru

# =============================================================================
# LEGACY VARIABLES (deprecated, kept for backward compatibility)
# =============================================================================
# These variables are still supported but will be removed in future versions.
# Use the new variables above instead.
#
# Legacy: Use PROXY_BASE_URL or DIRECT_BASE_URL instead
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
#
# Legacy: Use PROXY_API_KEY or DIRECT_API_KEY instead
# AUTH_TOKEN=sk-admin74203
#
# Legacy: Use MODEL_NAME instead
# MODEL=colin/gpt-5.4
#
# Legacy: Use MODEL_CONTEXT_WINDOW instead
# CONTEXT_WINDOW=1000000
#
# Legacy: Use MODEL_MAX_OUTPUT_TOKENS instead
# MAX_OUTPUT_TOKENS=32768
#
# Legacy: Use REWRITE_BLOCK_TARGET_CHARS instead
# BLOCK_TARGET_CHARS=15000

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================
#
# --- Example 1: Proxy mode (recommended for local development) ---
# CONNECTION_PROFILE=proxy
# PROXY_BASE_URL=http://127.0.0.1:8000/v1
# PROXY_API_KEY=your-proxy-key
# MODEL_NAME=gemini/gemini-2.5-flash
#
# --- Example 2: Direct OpenAI connection ---
# CONNECTION_PROFILE=direct
# DIRECT_BASE_URL=https://api.openai.com/v1
# DIRECT_API_KEY=sk-your-openai-key
# MODEL_NAME=openai/gpt-4o
#
# --- Example 3: Auto mode with fallback ---
# CONNECTION_PROFILE=auto
# PROXY_BASE_URL=http://127.0.0.1:8000/v1
# PROXY_API_KEY=your-proxy-key
# DIRECT_BASE_URL=https://api.openai.com/v1
# DIRECT_API_KEY=sk-your-openai-key
# MODEL_NAME=gpt-4o
# =============================================================================
